APP_NAME=Goravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=120

APP_URL=http://localhost
APP_HOST=127.0.0.1
APP_PORT=3000

JWT_SECRET=

# Application database (Goravel ORM) — e.g. docker compose appdb on 5433
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=chatdb_app
DB_USERNAME=chatdb
DB_PASSWORD=chatdb

# Optional: OpenAI for /api/connections/{id}/ai/chat (schema-only prompts)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

GRPC_HOST=
GRPC_PORT=

MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
